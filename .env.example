# Core storage
WAYBOOK_DATABASE_PATH=./data/waybook.sqlite
WAYBOOK_EXPORT_ROOT=./data/obsidian
WAYBOOK_PROJECT_REGISTRY_PATH=./data/project-registry.json

# Optional live connector roots
# Use your platform path separator when listing multiple directories.
# Linux/macOS: :
# Windows: ;
WAYBOOK_CLAUDE_PROJECT_ROOTS=/home/you/.claude/projects
WAYBOOK_CODEX_SESSION_ROOTS=/home/you/.codex/sessions
WAYBOOK_CLAUDE_MEM_DB_PATH=/home/you/.claude-mem/claude-mem.db
WAYBOOK_REPO_ROOTS=/abs/path/to/repo-one:/abs/path/to/repo-two
WAYBOOK_EXPERIMENT_ROOTS=/abs/path/to/experiments

# Connector switches
WAYBOOK_SEEDED_SOURCES_ENABLED=false

# Optional LLM secretary layer
# Leave these unset to stay deterministic-only.
WAYBOOK_LLM_PROVIDER=openai-compatible
WAYBOOK_LLM_MODEL=gpt-5-mini
WAYBOOK_LLM_API_KEY=
WAYBOOK_LLM_BASE_URL=https://api.openai.com/v1
WAYBOOK_LLM_GENERATION_ENABLED=true

# Optional review export behavior
WAYBOOK_SECRETARY_AUTOGENERATE_ON_READ=true
